name: Exos+ AI News Runner

on:
  push:
    branches: [ main, master ]
  workflow_dispatch:   # biar bisa di-run manual dari GitHub

jobs:
  run-ai:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'   # lebih stabil, tidak kena warning end-of-life

      - name: Install dependencies
        run: |
          pip install --upgrade pip
          pip install google-genai   # library terbaru dari Google

      - name: Run Exos+ Agent
        env:
          GOOGLE_API_KEY: ${{ secrets.GOOGLE_API_KEY }}
        run: python agents/news_agent.py
